# ── AI Providers — add only the keys for providers you use ───────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...


# ── Search (Tavily is default) ────────────────────────────────────────────────
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/premarket_advisor
REDIS_URL=                      # optional — omit or leave blank to disable Redis

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development             # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
